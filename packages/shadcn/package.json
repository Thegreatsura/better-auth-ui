{
  "name": "@better-auth-ui/shadcn",
  "version": "0.0.0-alpha.0",
  "type": "module",
  "scripts": {
    "build": "tsc && tsc-alias && bun styles",
    "dev": "bun styles && concurrently 'tsc -w' 'tsc-alias -w'",
    "styles": "cpy src/styles.css dist/ --flat",
    "test": "vitest",
    "registry:build": "shadcn build --output ../../apps/docs/public/r"
  },
  "files": [
    "src",
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core.js",
      "types": "./dist/core.d.ts"
    },
    "./react": {
      "import": "./dist/react-exports.js",
      "types": "./dist/react-exports.d.ts"
    },
    "./styles": "./dist/styles.css"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.2",
    "better-auth": "^1.5.6",
    "concurrently": "^9.2.1",
    "cpy-cli": "^7.0.0",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tsc-alias": "^1.8.16",
    "bowser": "^2.11.0",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@better-auth-ui/core": "*",
    "@fontsource-variable/inter": "^5.2.8",
    "@tanstack/react-form": "^1.28.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "radix-ui": "^1.4.3",
    "shadcn": "^4.1.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "peerDependencies": {
    "@better-auth-ui/react": "*",
    "better-auth": ">=1.5.6",
    "react": ">=19.2.4",
    "react-dom": ">=19.2.4",
    "sonner": ">=2.0.0",
    "bowser": ">=2.11.0"
  }
}
