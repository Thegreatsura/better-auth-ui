{
  "name": "@better-auth-ui/heroui",
  "version": "1.6.1",
  "type": "module",
  "scripts": {
    "build": "tsc && bun styles",
    "dev": "bun styles && tsc --watch",
    "styles": "cpy src/styles.css dist/ --flat",
    "test": "vitest"
  },
  "files": [
    "src",
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core.js",
      "types": "./dist/core.d.ts"
    },
    "./react": {
      "import": "./dist/react-exports.js",
      "types": "./dist/react-exports.d.ts"
    },
    "./styles": "./dist/styles.css"
  },
  "devDependencies": {
    "@gravity-ui/icons": "^2.18.0",
    "@heroui/react": "^3.0.2",
    "@heroui/styles": "^3.0.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.4",
    "better-auth": "^1.6.4",
    "cpy-cli": "^7.0.0",
    "playwright": "^1.59.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "bowser": "^2.11.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@better-auth-ui/core": "*",
    "@better-auth-ui/react": "*"
  },
  "peerDependencies": {
    "@gravity-ui/icons": ">=2.18.0",
    "@heroui/react": ">=3.0.2",
    "@heroui/styles": ">=3.0.2",
    "better-auth": ">=1.6.4",
    "react": ">=19.2.5",
    "react-dom": ">=19.2.5",
    "bowser": ">=2.11.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/better-auth-ui/better-auth-ui",
    "directory": "packages/heroui"
  },
  "publishConfig": {
    "access": "public"
  }
