.DS_Store
# Keep the fumadocs-typescript generator cache in git: AutoTypeTable type
# generation for 300+ tables costs ~3-5 minutes of TypeScript checker time on
# every cold CI/Cloudflare build without it. Entries are content-hash keyed
# portable JSON; stale entries are ignored and regenerated automatically.
.cache/*
!.cache/fumadocs-typescript
.vercel
.output
.nitro
/build/
/api/
/server/build
/public/build
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
.tanstack

src/routeTree.gen.ts
.source
