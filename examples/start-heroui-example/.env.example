# Needed so magic-link and password-reset URLs in email match your dev server (vite port 3000)
# BETTER_AUTH_URL=http://localhost:3000

# Magic link + password reset emails (local Mailpit: SMTP 1025, web UI http://127.0.0.1:8025)
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
MAIL_FROM=Better Auth UI <noreply@localhost>
# Optional if your SMTP server requires auth (Mailpit usually does not)
# SMTP_USER=
# SMTP_PASSWORD=
